# Google Cloud
GCP_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=marketing_analytics

# Google Ads
# Get developer token: https://developers.google.com/google-ads/api/docs/first-call/dev-token
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-oauth-client-id
GOOGLE_ADS_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
GOOGLE_ADS_CUSTOMER_ID=123-456-7890

# GA4
# Property ID is the number in your GA4 URL: analytics.google.com/analytics/web/#/p<PROPERTY_ID>
GA4_PROPERTY_ID=123456789
GA4_CLIENT_ID=your-oauth-client-id
GA4_CLIENT_SECRET=your-oauth-client-secret
GA4_REFRESH_TOKEN=your-refresh-token

# Google Search Console
# Exact site URL as it appears in Search Console (include trailing slash if present)
SEARCH_CONSOLE_SITE_URL=https://www.yoursite.com/
SC_CLIENT_ID=your-oauth-client-id
SC_CLIENT_SECRET=your-oauth-client-secret
SC_REFRESH_TOKEN=your-refresh-token

# Sync config
LOOKBACK_DAYS=90
