# Sanity — copy to .env.local and fill in your values
# Project ID found in sanity.io → your project → API settings
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Dataset name (default: production)
NEXT_PUBLIC_SANITY_DATASET=production

# Contentful (legacy — no longer used)
CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN=
CONTENTFUL_PREVIEW_ACCESS_TOKEN=
